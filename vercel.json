{
  "version": 2,
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/(script.js|style.css|informacion.txt|informacion.js)", "destination": "/public/$1" },
    { "source": "/img/(.*)", "destination": "/public/img/$1" }
  ]
}
